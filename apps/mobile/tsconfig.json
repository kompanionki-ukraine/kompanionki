{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2019", "es2020.bigint", "es2020.date", "es2020.number", "es2020.promise", "es2020.string", "es2020.symbol.wellknown", "es2021.promise", "es2021.string", "es2021.weakref", "es2022.array", "es2022.object", "es2022.string"],
    "jsx": "react-native",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@kompanionki/shared": ["../../packages/shared/src/index.ts"],
      "@kompanionki/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "android", "ios", "__tests__"]
}
