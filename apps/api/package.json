{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -fk ../../.env.keys -f .env.development -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "dotenvx run -fk ../../.env.keys -f .env.production --ignore MISSING_ENV_FILE -- node dist/index.js",
    "lint": "tsc --noEmit",
    "db:migrate": "dotenvx run -fk ../../.env.keys -f .env.development -- prisma migrate dev",
    "db:migrate:deploy": "dotenvx run -fk ../../.env.keys -f .env.production --ignore MISSING_ENV_FILE -- prisma migrate deploy",
    "db:seed": "dotenvx run -fk ../../.env.keys -f .env.development -- tsx prisma/seed.ts",
    "db:studio": "dotenvx run -fk ../../.env.keys -f .env.development -- prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.65.0",
    "@kompanionki/shared": "*",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.47.10",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
